{
    email {$LETSENCRYPT_EMAIL}
}

{$APP_DOMAIN} {
    encode gzip

    handle /api/* {
        reverse_proxy api:8000
    }

    handle /health {
        reverse_proxy api:8000
    }

    handle {
        reverse_proxy web:80
    }
}

www.{$APP_DOMAIN} {
    redir https://{$APP_DOMAIN}{uri} permanent
}

api.{$APP_DOMAIN} {
    encode gzip
    reverse_proxy api:8000
}
